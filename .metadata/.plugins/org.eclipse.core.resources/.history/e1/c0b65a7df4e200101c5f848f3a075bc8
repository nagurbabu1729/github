package com.Mail.Email.Service;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.mail.SimpleMailMessage;
import org.springframework.mail.javamail.JavaMailSender;
import org.springframework.stereotype.Service;

@Service
public class EmailService {
	
	@Autowired
	private JavaMailSender mailSender;
	
	public void sendMail() {
		
		SimpleMailMessage message = new SimpleMailMessage();
		message.setFrom("uppalapatinagurbabu@gmail.com");
		message.setTo("nagurbabuuppalpati225@gmail.com");
		message.setCc("nagurbabuuppalapati@gmail.com");
		message.setText("welcome to the email services from spring boot applications");
		
		mailSender.send(message);
	}
	
	
}